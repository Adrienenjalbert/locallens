{
  "name": "locallens",
  "private": true,
  "version": "0.1.0",
  "description": "LocalLens — a config-driven local-intent engine that monetises one data asset three ways: affiliate, CRM subscriptions, and lead-gen, optimised by a CRISP-DM loop. Next.js static export hosted on GitHub Pages.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"config/**/*.ts\"",
    "db:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "test": "vitest run",
    "outreach": "tsx tools/outreach/index.ts",
    "seo": "tsx tools/seo/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.451.0",
    "next": "^14.2.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.13",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
