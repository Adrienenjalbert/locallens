# ──────────────────────────────────────────────────────────────────────────
# LocalLens environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# Front-end only ever uses the ANON key + public URL. All privileged keys
# (service role, Google Places, Apify, SEMrush, Stripe, Twilio, affiliate
# network keys) live in Supabase Edge Function secrets — NOT here.
# ──────────────────────────────────────────────────────────────────────────

# --- Public (safe to expose to the browser; inlined by Next at build time) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For GitHub Pages PROJECT sites served under https://<user>.github.io/<repo>,
# set this to "/<repo>" (the deploy workflow sets it automatically). Leave empty
# for a user/org page or a custom domain.
NEXT_PUBLIC_BASE_PATH=

# --- Server-side ONLY: set these via `supabase secrets set ...`, not in the FE ---
# SUPABASE_SERVICE_ROLE_KEY=
# GOOGLE_PLACES_API_KEY=
# APIFY_TOKEN=
# SEMRUSH_API_KEY=
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=
# TWILIO_AUTH_TOKEN=
# Affiliate networks (server-side resolution + postback verification):
# AWIN_API_TOKEN=
# IMPACT_API_KEY=
# CJ_API_KEY=
# PARTNERSTACK_API_KEY=
